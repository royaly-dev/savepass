{
    "manifest_version": 3,
    "browser_specific_settings": {
        "gecko": {
            "id": "{94cb1ce1-a416-523b-b1a6-01506768b349}"
        }
    },
    "name": "SavePass",
    "version": "0.0.10",
    "description": "SavePass extention for web.",
    "icons": {
        "256": "icon-256.png"
    },
    "action": {
        "default_icon": {
            "256": "icon-256.png"
        },
        "default_title": "SavePass",
        "default_popup": "popup.html"
    },
    "permissions": [
        "storage",
        "tabs"
    ],
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "assets/content.js"
            ]
        }
    ],
    "background": {
        "scripts": [
            "assets/background.js"
        ],
        "service_worker": "assets/background.js"
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' http://localhost:5263 http://localhost:5263/*"
    }
}